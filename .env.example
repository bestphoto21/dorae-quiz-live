# Supabase project URL.
# Find this in Supabase Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe Supabase key.
# Use the Supabase publishable key or anon public key here.
# NEXT_PUBLIC_ variables are the only Supabase values that may be used in browser code.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key.
# Never expose this in browser code.
# Never commit a real secret/service_role key to Git.
SUPABASE_SERVICE_ROLE_KEY=
